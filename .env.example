# If DATABASE_URL is unset and state/.setup-complete is absent, the app boots
# the setup wizard at http://localhost:3000/setup. The wizard writes a real
# .env into state/.env after the admin completes setup.

# DATABASE_URL=postgresql://celphei:celphei@localhost:5432/celphei?schema=public

# Required when DATABASE_URL is set (wizard generates these automatically otherwise)
# SESSION_SECRET=
# HEALTH_TOKEN=
# METRICS_TOKEN=
# ENCRYPTION_KEY=                  # AES-256-GCM key for IntegrationConnection secrets

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
METRICS_ENABLED=true
TRUST_PROXY=false

# Polaris integration (optional; wizard step 5 sets these. Env wins over DB.)
# POLARIS_BASE_URL=https://polaris.example.com
# POLARIS_API_TOKEN=

# Web (Vite)
VITE_API_BASE_URL=http://localhost:3000
